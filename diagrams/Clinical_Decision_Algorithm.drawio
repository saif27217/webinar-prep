<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="app.diagrams.net" modified="2026-07-12T00:00:00.000Z" agent="Hermes" version="24.0.0" type="device">
  <diagram id="clinical-decision" name="Clinical Decision Algorithm">
    <mxGraphModel dx="1800" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1920" pageHeight="1080" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Title -->
        <mxCell id="title" value="IDDM Clinical Decision Algorithm" style="text;html=1;fontSize=32;fontStyle=1;fontColor=#e8e8ed;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="560" y="20" width="800" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="subtitle" value="From Risk Screening to Staged Management" style="text;html=1;fontSize=18;fontColor=#8b8b9e;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="660" y="65" width="600" height="30" as="geometry"/>
        </mxCell>

        <!-- START: At-Risk Individual -->
        <mxCell id="start" value="At-Risk Individual&#xa;(Family history, genetic risk,&#xa;incidental finding)" style="shape=ellipse;whiteSpace=wrap;html=1;fontSize=16;fontStyle=1;fontColor=#ffffff;fillColor=#5b5bd6;strokeColor=#7c7cf7;strokeWidth=2;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="760" y="110" width="280" height="100" as="geometry"/>
        </mxCell>

        <!-- Step 1: Autoantibody Panel -->
        <mxCell id="step1" value="STEP 1: Autoantibody Panel&#xa;&#xa;GADA + IA-2A + IAA + ZnT8A&#xa;(Minimum 2, preferably all 4)" style="rounded=1;whiteSpace=wrap;html=1;fontSize=16;fontColor=#e8e8ed;fillColor=#111113;strokeColor=#5b5bd6;strokeWidth=2;shadow=1;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="735" y="250" width="330" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#5b5bd6;strokeWidth=2;" edge="1" source="start" target="step1" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Decision: Any positive? -->
        <mxCell id="dec1" value="Any Autoantibody&#xa;Positive?" style="shape=rhombus;whiteSpace=wrap;html=1;fontSize=16;fontStyle=1;fontColor=#e8e8ed;fillColor=#1a1a2e;strokeColor=#5b5bd6;strokeWidth=2;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="785" y="390" width="230" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="e2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#5b5bd6;strokeWidth=2;" edge="1" source="step1" target="dec1" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- NO branch: Monitor -->
        <mxCell id="monitor" value="Re-screen in 1-3 years&#xa;or if symptoms develop" style="rounded=1;whiteSpace=wrap;html=1;fontSize=14;fontColor=#8b8b9e;fillColor=#111113;strokeColor=#232329;strokeWidth=1;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="1140" y="410" width="220" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="e_no" value="No" style="edgeStyle=orthogonalEdgeStyle;rounded=1;fontSize=14;fontColor=#8b8b9e;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeColor=#8b8b9e;strokeWidth=1;dashed=1;" edge="1" source="dec1" target="monitor" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- YES branch -->
        <mxCell id="step2" value="STEP 2: Confirm with&#xa;HLA Genotyping&#xa;&#xa;DR3/DR4 heterozygote = highest risk (OR 15-20)" style="rounded=1;whiteSpace=wrap;html=1;fontSize=15;fontColor=#e8e8ed;fillColor=#111113;strokeColor=#22c55e;strokeWidth=2;shadow=1;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="735" y="550" width="330" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="e_yes" value="Yes (1+ positive)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;fontSize=14;fontColor=#22c55e;fontStyle=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#22c55e;strokeWidth=2;" edge="1" source="dec1" target="step2" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Step 3: Metabolic Assessment -->
        <mxCell id="step3" value="STEP 3: Metabolic Assessment&#xa;&#xa;Fasting glucose + OGTT + HbA1c&#xa;C-peptide (fasting + MMTT)" style="rounded=1;whiteSpace=wrap;html=1;fontSize=15;fontColor=#e8e8ed;fillColor=#111113;strokeColor=#5b5bd6;strokeWidth=2;shadow=1;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="735" y="690" width="330" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="e3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#5b5bd6;strokeWidth=2;" edge="1" source="step2" target="step3" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Decision: Staging -->
        <mxCell id="dec2" value="Dysglycemia&#xa;Present?" style="shape=rhombus;whiteSpace=wrap;html=1;fontSize=16;fontStyle=1;fontColor=#e8e8ed;fillColor=#1a1a2e;strokeColor=#5b5bd6;strokeWidth=2;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="785" y="830" width="230" height="110" as="geometry"/>
        </mxCell>
        <mxCell id="e4" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#5b5bd6;strokeWidth=2;" edge="1" source="step3" target="dec2" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Stage Boxes -->
        <!-- Stage 1 -->
        <mxCell id="stage1" value="STAGE 1&#xa;Pre-symptomatic T1D&#xa;&#xa;2+ autoantibodies&#xa;Normal glucose" style="rounded=1;whiteSpace=wrap;html=1;fontSize=15;fontColor=#e8e8ed;fillColor=#111113;strokeColor=#ef4444;strokeWidth=2;shadow=1;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="260" y="960" width="240" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="e_no_dys" value="No" style="edgeStyle=orthogonalEdgeStyle;rounded=1;fontSize=14;fontColor=#ef4444;fontStyle=1;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#ef4444;strokeWidth=2;" edge="1" source="dec2" target="stage1" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Stage 2 -->
        <mxCell id="stage2" value="STAGE 2&#xa;Pre-symptomatic T1D&#xa;&#xa;2+ autoantibodies&#xa;Dysglycemia (no symptoms)" style="rounded=1;whiteSpace=wrap;html=1;fontSize=15;fontColor=#e8e8ed;fillColor=#111113;strokeColor=#f59e0b;strokeWidth=2;shadow=1;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="580" y="960" width="240" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="e_yes_dys" value="Yes" style="edgeStyle=orthogonalEdgeStyle;rounded=1;fontSize=14;fontColor=#f59e0b;fontStyle=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#f59e0b;strokeWidth=2;" edge="1" source="dec2" target="stage2" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Stage 3 -->
        <mxCell id="stage3" value="STAGE 3&#xa;Clinical Onset&#xa;&#xa;2+ autoantibodies&#xa;Symptomatic hyperglycemia" style="rounded=1;whiteSpace=wrap;html=1;fontSize=15;fontColor=#e8e8ed;fillColor=#111113;strokeColor=#ef4444;strokeWidth=2;shadow=1;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="900" y="960" width="240" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="e_symptoms" value="Symptoms&#xa;present" style="edgeStyle=orthogonalEdgeStyle;rounded=1;fontSize=13;fontColor=#ef4444;fontStyle=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#ef4444;strokeWidth=2;" edge="1" source="dec2" target="stage3" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Teplizumab callout -->
        <mxCell id="teplizumab" value="TEPLIZUMAB&#xa;Delays Stage 3 by ~2 years&#xa;FDA approved (Tzield)" style="shape=note;whiteSpace=wrap;html=1;fontSize=14;fontStyle=1;fontColor=#22c55e;fillColor=#0a1a0f;strokeColor=#22c55e;strokeWidth=2;shadow=1;size=15;" vertex="1" parent="1">
          <mxGeometry x="1280" y="700" width="250" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="e_tez" style="edgeStyle=orthogonalEdgeStyle;rounded=1;dashed=1;dashPattern=5 5;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;strokeColor=#22c55e;strokeWidth=1;" edge="1" source="stage2" target="teplizumab" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Key box -->
        <mxCell id="keybox" value="Panel Sensitivity:&#xa;  1 antibody: ~65%&#xa;  2 antibodies: ~80%&#xa;  3 antibodies: ~90%&#xa;  4 antibodies: >95%" style="rounded=1;whiteSpace=wrap;html=1;fontSize=14;fontColor=#e8e8ed;fillColor=#111113;strokeColor=#232329;strokeWidth=1;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="40" y="110" width="230" height="120" as="geometry"/>
        </mxCell>

        <!-- Footer -->
        <mxCell id="footer" value="Based on ISPAD 2024 Guidelines  |  ADA Standards of Care 2025" style="text;html=1;fontSize=12;fontColor=#5a5a6e;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="660" y="1050" width="600" height="25" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
